.badge {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  color: #20211F;
  font-size: 24rpx;
  font-weight: 600;
}

.normal,
.low {
  background: #DCEBDF;
}

.medium {
  background: #F3E3B4;
}

.high {
  background: #F4C8C2;
}
