.page {
  min-height: 100vh;
  width: 100%;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 32rpx 32rpx 248rpx;
  box-sizing: border-box;
}

.field-row {
  display: flex;
  gap: 24rpx;
}

.avatar-btn {
  position: relative;
  flex: 0 0 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx !important;
  max-width: 80rpx;
  height: 80rpx;
  min-height: 80rpx;
  min-width: 80rpx !important;
  margin: 0;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
  border: 0;
  border-radius: 8rpx;
  background: #FFFEF9;
  color: #20211F;
  line-height: 1;
}

.avatar-btn::after {
  border: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.profile-hero {
  min-height: 264rpx;
  margin: 12rpx 0 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  display: grid;
  align-content: space-between;
  background: #FFFEF9;
}

.profile-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.name-field {
  flex: 1;
  min-width: 0;
}

.profile-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.info-list {
  display: grid;
  gap: 0;
}

.info-item {
  min-height: 80rpx;
  border-bottom: 2rpx solid #DEDED5;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 24rpx;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
}

.info-item:last-child {
  border-bottom: 0;
}

.info-control,
.inline-control {
  color: #74766F;
  font-weight: 500;
}

.info-control {
  min-width: 180rpx;
  text-align: right;
}

.inline-control {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  min-width: 148rpx;
}

.form.panel {
  padding-bottom: 28rpx;
}

.status-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 80rpx;
  min-height: 80rpx;
  padding: 0;
  box-sizing: border-box;
  text-align: center;
  line-height: 1;
}

.status-badge-text {
  display: block;
  line-height: 1;
  transform: translateY(1rpx);
}

.field {
  display: block;
  margin-top: 20rpx;
}

.field.half {
  flex: 1;
  min-width: 0;
}

.compact-field {
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
}

input,
textarea,
.picker {
  width: 100%;
  min-height: 80rpx;
  margin-top: 10rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  color: #20211F;
  font-size: 28rpx;
}

.baby-name-input {
  width: 100%;
  min-height: 80rpx;
  margin-top: 12rpx;
  padding: 0;
  border: 0;
  background: transparent;
  font-family: "Avenir Next", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 40rpx;
  line-height: 80rpx;
  font-weight: 600;
}

.info-input {
  width: 104rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: #74766F;
  font-size: 28rpx;
  line-height: 56rpx;
  text-align: right;
  font-weight: 500;
}

.compact-input-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
  color: #74766F;
  font-size: 28rpx;
}

.compact-input {
  flex: 0 0 140rpx;
  width: 140rpx;
  min-height: 54rpx;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  font-size: 28rpx;
}

.field-help {
  display: block;
  margin-top: 10rpx;
  color: #74766F;
  font-size: 24rpx;
  line-height: 1.45;
}

textarea {
  min-height: 128rpx;
  padding-top: 22rpx;
}

.picker {
  line-height: 80rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx;
  margin-top: 20rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  font-size: 28rpx;
}

.error {
  display: block;
  margin-top: 20rpx;
  color: #C94F45;
  font-size: 24rpx;
}

.save {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  min-height: 80rpx;
  margin-top: 28rpx;
  padding: 0;
  border-radius: 8rpx;
  background: #20211F;
  color: #FFFEF9;
  font-size: 28rpx;
  line-height: 80rpx;
}

.save::after {
  border: 0;
}
