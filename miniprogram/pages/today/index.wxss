.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 204rpx;
  box-sizing: border-box;
}

.hero-metric {
  margin: 16rpx 8rpx 28rpx;
  padding: 44rpx 0 40rpx;
  border-top: 3rpx solid #20211F;
  border-bottom: 3rpx solid #20211F;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 24rpx;
  align-items: end;
}

.metric-value {
  display: block;
  font-family: Georgia, "Songti SC", serif;
  font-size: 120rpx;
  line-height: 0.95;
  font-weight: 600;
  color: #20211F;
}

.metric-value text {
  font-size: 40rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.tile {
  min-height: 172rpx;
  padding: 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8px;
  background: #FFFEFB;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.tile-value {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.risk-line {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 20rpx;
  align-items: center;
  color: #74766F;
  font-size: 26rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #20211F;
  border-radius: 999px;
  background: #F3D98B;
}

.risk-value {
  color: #20211F;
  font-weight: 800;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.quick {
  min-height: 140rpx;
  border: 2rpx solid #20211F;
  border-radius: 8px;
  background: #FFFEF9;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.quick text:first-child {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #20211F;
  border-radius: 999px;
  background: #DCEEE5;
  text-align: center;
  line-height: 44rpx;
}

.quick.sky text:first-child {
  background: #DFEAF7;
}

.quick.amber text:first-child {
  background: #F3D98B;
}
