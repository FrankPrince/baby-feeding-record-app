.page {
  min-height: 100vh;
  width: 100%;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 32rpx 32rpx 248rpx;
  box-sizing: border-box;
}

.hero-metric {
  margin: 12rpx 0 28rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 24rpx;
  align-items: end;
}

.metric-value {
  display: block;
  font-family: "Avenir Next", "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 80rpx;
  line-height: 0.95;
  font-weight: 600;
  color: #20211F;
}

.metric-value text {
  font-size: 28rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.tile {
  min-height: 144rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.tile-value {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.risk-line {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 20rpx;
  align-items: center;
  color: #74766F;
  font-size: 28rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #20211F;
  border-radius: 999px;
  background: #F3D98B;
}

.risk-value {
  color: #20211F;
  font-weight: 600;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.quick {
  min-height: 128rpx;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.quick text:first-child {
  width: 48rpx;
  height: 48rpx;
  border: 0;
  border-radius: 8rpx;
  background: #DCEEE5;
  text-align: center;
  line-height: 44rpx;
}

.quick.sky text:first-child {
  background: #DFEAF7;
}

.quick.amber text:first-child {
  background: #F3D98B;
}
