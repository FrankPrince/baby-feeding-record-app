<view class="page">
  <view class="appbar">
    <view>
      <text class="app-title">今日</text>
      <text class="app-subtitle">{{overview.baby.subtitle}}</text>
    </view>
  </view>

  <view class="panel quick-panel">
    <view class="panel-head">
      <text class="panel-title">快速记录</text>
    </view>
    <view class="quick-actions">
      <view class="quick" data-type="feeding" bindtap="onQuickRecordTap" hover-class="quick-hover" hover-stay-time="80">
        <text class="quick-icon">+</text>
        <text class="quick-label">喂奶</text>
      </view>
      <view class="quick sky" data-type="diaper" bindtap="onQuickRecordTap" hover-class="quick-hover" hover-stay-time="80">
        <text class="quick-icon">+</text>
        <text class="quick-label">尿便</text>
      </view>
      <view class="quick amber" data-type="jaundice" bindtap="onQuickRecordTap" hover-class="quick-hover" hover-stay-time="80">
        <text class="quick-icon">+</text>
        <text class="quick-label">黄疸</text>
      </view>
    </view>
  </view>

  <view class="hero-metric">
    <view>
      <text class="label">今日总奶量</text>
      <view class="metric-value">{{overview.feeding.totalAmountMl}}<text> ml</text></view>
    </view>
    <text class="badge {{overview.feeding.milkStatus.status === '达标' ? '' : 'warn'}}">{{overview.feeding.milkStatus.status}}</text>
  </view>

  <view class="grid-2">
    <view class="tile">
      <text class="label">喂养次数</text>
      <text class="tile-value">{{overview.feeding.totalCount}}</text>
    </view>
    <view class="tile">
      <text class="label">建议区间</text>
      <text class="tile-value">{{overview.feeding.milkStatus.lowerLimitMl || '--'}} - {{overview.feeding.milkStatus.upperLimitMl || '--'}} ml</text>
    </view>
    <view class="tile">
      <text class="label">尿尿</text>
      <text class="tile-value">{{overview.diaper.peeCount}} 次</text>
    </view>
    <view class="tile">
      <text class="label">便便</text>
      <text class="tile-value">{{overview.diaper.poopCount}} 次</text>
    </view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <text class="panel-title">最近黄疸</text>
      <risk-badge label="{{overview.jaundice.riskLabel}}" level="{{overview.jaundice.riskLevel}}" />
    </view>
    <view wx:if="{{overview.jaundice.hasRecord}}" class="risk-line">
      <view class="dot"></view>
      <text>{{overview.jaundice.timeSinceLastRecordText}} · {{overview.jaundice.changeText}}</text>
      <text class="risk-value">{{overview.jaundice.averageMgDl}} mg/dL</text>
    </view>
    <empty-state wx:else title="{{overview.jaundice.emptyText}}" />
    <view class="notice">{{overview.jaundice.referenceNote}}</view>
  </view>
</view>
