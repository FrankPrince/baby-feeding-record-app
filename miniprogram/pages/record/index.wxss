.page {
  min-height: 100vh;
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding: 32rpx 32rpx 288rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.segmented {
  display: flex;
  gap: 16rpx;
  padding: 8rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #EEEEE7;
}

.panel,
.segmented,
.appbar {
  width: 100%;
  max-width: 100%;
}

.segmented button {
  flex: 1;
  box-sizing: border-box;
  height: 80rpx;
  min-height: 80rpx;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 0;
  border-radius: 8rpx;
  background: transparent;
  color: #74766F;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
}

.segmented button.active {
  background: #FFFEF9;
  color: #20211F;
}

.record-row {
  margin-top: 18rpx;
  min-height: 128rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 24rpx;
  align-items: center;
}

.form-panel {
  display: grid;
  gap: 24rpx;
  overflow: hidden;
}

.field,
.time-grid,
.action-row,
.type-row,
.quick-row,
.color-grid,
.diaper-type-row,
.diaper-choice-row {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.type-row,
.quick-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  row-gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.diaper-type-row,
.diaper-choice-row {
  display: grid;
  justify-content: stretch;
  column-gap: 16rpx;
  padding: 0 10rpx;
}

.diaper-type-row,
.diaper-choice-row {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.action-row {
  display: flex;
  gap: 24rpx;
  align-items: center;
  flex-wrap: wrap;
}

.diaper-action-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
}

.type-btn,
.quick-btn,
.color-btn,
.save,
.secondary {
  box-sizing: border-box;
  margin: 0;
  border: 0;
  border-radius: 8rpx;
  color: #20211F;
  font-weight: 600;
  transition: transform 120ms ease, opacity 120ms ease, background-color 120ms ease;
  max-width: 100%;
  min-width: 0;
}

.type-btn::after,
.quick-btn::after,
.color-btn::after,
.save::after,
.secondary::after,
.swipe-btn::after {
  border: 0;
}

.type-btn {
  flex: 0 0 calc((100% - 24rpx) / 2);
  width: calc((100% - 24rpx) / 2);
  max-width: calc((100% - 24rpx) / 2);
  min-width: 0;
  height: 80rpx;
  min-height: 80rpx;
  background: #FFFEF9;
  font-size: 28rpx;
  line-height: 80rpx;
}

.type-btn.active {
  background: #DCEEE5;
  color: #1E6B4F;
}

.diaper-type-btn {
  width: 100%;
  max-width: 100%;
  background: #EEEEE7;
  color: #20211F;
  font-size: 26rpx;
}

.diaper-type-btn.active {
  background: #DCEEE5;
  color: #1E6B4F;
}

.quick-btn {
  flex: 0 0 calc((100% - 24rpx) / 2);
  width: calc((100% - 24rpx) / 2);
  max-width: calc((100% - 24rpx) / 2);
  height: 80rpx;
  min-height: 80rpx;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0;
  background: #EEEEE7;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
}

.quick-btn.active {
  background: #F3D98B;
  color: #795C00;
}

.quick-btn.active .quick-unit {
  color: #795C00;
}

.choice-btn-hover,
.quick-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.quick-btn-hover {
  background: #E4E4DC;
}

.quick-btn.active.quick-btn-hover {
  background: #EBCB6C;
}

.quick-unit {
  color: #74766F;
  font-size: 24rpx;
  font-weight: 600;
}

.color-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  width: auto;
  margin: 0 32rpx;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
}

.color-btn {
  width: 100%;
  height: 80rpx;
  min-height: 80rpx;
  box-shadow: inset 0 0 0 2rpx rgba(32, 33, 31, 0.08);
  font-size: 28rpx;
  line-height: 80rpx;
}

.color-btn.active {
  box-shadow: inset 0 0 0 4rpx #20211F;
}

.color-yellow {
  background: #F3D98B;
  color: #4F3B00;
}

.color-green {
  background: #DCEEE5;
  color: #1E6B4F;
}

.color-brown {
  background: #B9805A;
  color: #FFFEF9;
}

.color-black {
  background: #20211F;
  color: #FFFEF9;
}

.color-black.active {
  box-shadow: inset 0 0 0 4rpx #FFFEF9;
}

.color-red {
  background: #C94F3A;
  color: #FFFEF9;
}

.color-gray_white {
  background: #E2E2DC;
  color: #20211F;
}

.color-white {
  background: #FFFEF9;
  color: #20211F;
  box-shadow: inset 0 0 0 2rpx #C9C9C0;
}

.color-white.active {
  box-shadow: inset 0 0 0 4rpx #20211F;
}

.color-other {
  background: #D8E6EE;
  color: #254B5E;
}

.amount-choice {
  width: 100%;
  max-width: 100%;
}

.compact {
  flex: 0 0 auto;
  min-width: 144rpx;
  padding: 0 20rpx;
}

.field {
  display: grid;
  gap: 12rpx;
}

.field-input,
.picker-control,
textarea {
  width: 100%;
  min-height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  font-size: 28rpx;
}

.field picker {
  display: block;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

textarea {
  min-height: 128rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.picker-control {
  display: flex;
  align-items: center;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.time-grid .field {
  min-width: 0;
}

.save {
  height: 80rpx;
  min-height: 80rpx;
  width: 100%;
  background: #20211F;
  color: #FFFEF9;
  line-height: 80rpx;
}

.action-row .save {
  flex: 1 1 0;
}

.diaper-action-row .save {
  flex: none;
}

.secondary {
  height: 80rpx;
  min-height: 80rpx;
  width: 100%;
  padding: 0 28rpx;
  background: #EEEEE7;
  line-height: 80rpx;
}

.error {
  color: #9A3C28;
  font-size: 24rpx;
  font-weight: 700;
}

.record-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.record-sub {
  display: block;
  margin-top: 10rpx;
  color: #74766F;
  font-size: 24rpx;
}

.attention-copy {
  color: #9A3C28;
  font-weight: 600;
}

.feeding-record {
  align-items: start;
}

.history-swipe {
  position: relative;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 8rpx;
  min-height: 128rpx;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 240rpx;
  padding: 0;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 120rpx 120rpx;
  align-items: stretch;
  overflow: hidden;
  background: transparent;
}

.swipe-btn {
  width: 120rpx;
  height: 100%;
  min-height: 128rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  color: #20211F;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.swipe-btn.edit {
  background: #F3D98B;
}

.swipe-btn.delete {
  background: #F3D0C7;
  color: #9A3C28;
}

.swipe-btn-hover {
  opacity: 0.9;
}

.swipe-label {
  display: block;
  line-height: 1.2;
}

.swipe-icon {
  position: relative;
  display: block;
  width: 28rpx;
  height: 28rpx;
  color: currentColor;
  box-sizing: border-box;
}

.edit-pencil {
  position: absolute;
  left: 6rpx;
  top: 11rpx;
  width: 22rpx;
  height: 6rpx;
  border-radius: 4rpx;
  background: currentColor;
  transform: rotate(-35deg);
  transform-origin: left center;
}

.edit-line {
  position: absolute;
  left: 2rpx;
  bottom: 3rpx;
  width: 14rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.delete-lid {
  position: absolute;
  left: 6rpx;
  top: 5rpx;
  width: 16rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.delete-bin {
  position: absolute;
  left: 7rpx;
  top: 11rpx;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 4rpx 4rpx;
  box-sizing: border-box;
}

.swipe-card {
  position: relative;
  z-index: 1;
  margin-top: 0;
  transition: transform 180ms ease;
}

.swipe-card.open {
  transform: translateX(-240rpx);
}

.chevron {
  color: #74766F;
  font-size: 28rpx;
  line-height: 1;
}

.amount {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  font-size: 30rpx;
  font-weight: 600;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

@media (max-width: 360px) {
  .time-grid,
  .record-row {
    grid-template-columns: 1fr;
  }
}

.tile {
  min-height: 144rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.tile-value {
  font-size: 30rpx;
  font-weight: 600;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background: rgba(32, 33, 31, 0.28);
}

.amount-dialog {
  width: 100%;
  max-width: 560rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
}

.dialog-head {
  margin-bottom: 24rpx;
}

.dialog-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.dialog-button {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  max-width: 100%;
}

.dialog-actions .save,
.dialog-actions .secondary {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  padding: 0;
}
