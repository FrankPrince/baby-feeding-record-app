<view class="page">
  <view class="appbar">
    <view>
      <text class="app-title">记录</text>
      <text class="app-subtitle">今天 · 待添加记录</text>
    </view>
    <view class="icon-btn">+</view>
  </view>

  <view class="segmented">
    <block wx:for="{{tabs}}" wx:key="*this">
      <button class="{{activeTab === index ? 'active' : ''}}" data-index="{{index}}" bindtap="onTabTap">{{item}}</button>
    </block>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view>
        <text class="panel-title">今日{{tabs[activeTab]}}</text>
        <text class="label">保存后会按时间倒序显示</text>
      </view>
      <text class="badge warn">0 条</text>
    </view>
    <view class="record-row">
      <view>
        <text class="record-title">暂无记录</text>
        <text class="record-sub">后续 Ticket 会补齐完整表单和历史编辑</text>
      </view>
      <text class="amount">--</text>
    </view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <text class="panel-title">尿便摘要</text>
      <text class="badge warn">关注颜色 0</text>
    </view>
    <view class="grid-2">
      <view class="tile"><text class="label">尿量</text><text class="tile-value">--</text></view>
      <view class="tile"><text class="label">颜色</text><text class="tile-value">--</text></view>
    </view>
  </view>
</view>
