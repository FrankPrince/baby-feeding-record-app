.page {
  min-height: 100vh;
  width: 100%;
  max-width: 760rpx;
  margin: 0 auto;
  padding: 32rpx 32rpx 248rpx;
  box-sizing: border-box;
}

.segmented {
  display: flex;
  gap: 16rpx;
  padding: 8rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #EEEEE7;
}

.segmented button {
  flex: 1;
  height: 80rpx;
  min-height: 80rpx;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 0;
  border-radius: 8rpx;
  background: transparent;
  color: #74766F;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
}

.segmented button.active {
  background: #FFFEF9;
  color: #20211F;
}

.range-tabs {
  margin-top: 16rpx;
}

.chart-wrap {
  width: 100%;
  min-height: 440rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
}

.trend-chart {
  display: block;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
}

.calendar-cell {
  min-width: 0;
  min-height: 104rpx;
  padding: 12rpx 6rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  text-align: center;
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
}

.calendar-cell.ok {
  border-color: #9FC7AA;
  background: #DCEEE5;
}

.calendar-cell.alert {
  border-color: #D99988;
  background: #F3D0C7;
}

.calendar-cell.empty {
  background: #EEEEE7;
  color: #74766F;
}

.calendar-cell.selected {
  border-color: #20211F;
  box-shadow: inset 0 0 0 999rpx rgba(32, 33, 31, 0.08), 0 8rpx 18rpx rgba(32, 33, 31, 0.12);
  transform: translateY(-2rpx);
}

.calendar-day,
.calendar-value {
  display: block;
  max-width: 100%;
  line-height: 1.2;
}

.calendar-day {
  color: #74766F;
  font-size: 20rpx;
  font-weight: 600;
}

.calendar-value {
  color: #20211F;
  font-size: 20rpx;
  font-weight: 600;
  word-break: break-all;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: rgba(32, 33, 31, 0.34);
}

.detail-dialog {
  width: 100%;
  max-width: 640rpx;
  max-height: 78vh;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: flex;
  flex-direction: column;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.detail-list {
  max-height: 52vh;
}

.detail-record {
  margin-top: 14rpx;
  min-height: 112rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #DEDED5;
  border-radius: 8rpx;
  background: #FFFEF9;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 20rpx;
  align-items: center;
}

.detail-copy {
  min-width: 0;
}

.detail-title {
  display: block;
  color: #20211F;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
}

.detail-line {
  display: block;
  margin-top: 8rpx;
  color: #74766F;
  font-size: 24rpx;
  line-height: 1.35;
  word-break: break-word;
}

.detail-close {
  width: 100%;
  height: 80rpx;
  min-height: 80rpx;
  margin-top: 20rpx;
  border: 0;
  border-radius: 8rpx;
  background: #20211F;
  color: #FFFEF9;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
}
