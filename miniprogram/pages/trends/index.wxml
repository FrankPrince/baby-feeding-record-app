<view class="page">
  <view class="appbar">
    <view>
      <text class="app-title">趋势</text>
      <text class="app-subtitle">近 {{ranges[activeRange]}}</text>
    </view>
    <view class="icon-btn">⌄</view>
  </view>

  <view class="segmented">
    <block wx:for="{{ranges}}" wx:key="*this">
      <button class="{{activeRange === index ? 'active' : ''}}" data-index="{{index}}" bindtap="onRangeTap">{{item}}</button>
    </block>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view>
        <text class="panel-title">奶量趋势</text>
        <text class="label">含建议区间参考线</text>
      </view>
      <text class="badge warn">暂无</text>
    </view>
    <view class="chart milk">
      <view class="band"></view>
      <view class="line line-a"></view>
      <view class="line line-b"></view>
      <view class="point p1"></view>
      <view class="point p2"></view>
      <view class="point p3"></view>
      <view class="point p4"></view>
    </view>
    <view class="legend">
      <text><text class="legend-dot ink"></text>总奶量</text>
      <text><text class="legend-dot mint"></text>建议区间</text>
      <text><text class="legend-dot sky"></text>次数</text>
    </view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <text class="panel-title">黄疸</text>
      <text class="badge warn">无法判断</text>
    </view>
    <view class="chart jaundice">
      <view class="danger-band"></view>
      <view class="watch-band"></view>
      <view class="line line-c"></view>
      <view class="point p5"></view>
      <view class="point p6"></view>
      <view class="point p7"></view>
    </view>
  </view>
</view>
