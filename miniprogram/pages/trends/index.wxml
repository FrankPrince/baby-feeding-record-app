<view class="page">
  <view class="appbar">
    <view>
      <text class="app-title">趋势</text>
      <text class="app-subtitle">{{viewModel.subtitle}}</text>
    </view>
  </view>

  <view class="segmented">
    <block wx:for="{{typeOptions}}" wx:key="value">
      <button class="{{activeType === item.value ? 'active' : ''}}" data-type="{{item.value}}" bindtap="onTypeTap">{{item.label}}</button>
    </block>
  </view>

  <view class="segmented range-tabs">
    <block wx:for="{{rangeOptions}}" wx:key="value">
      <button class="{{activeRangeValue == item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="onRangeTap">{{item.label}}</button>
    </block>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view>
        <text class="panel-title">{{viewModel.title}}</text>
        <text class="label">{{viewModel.subtitle}}</text>
      </view>
      <text class="badge {{viewModel.badgeStatusClass === 'alert' ? 'danger' : viewModel.badgeStatusClass === 'ok' ? '' : 'warn'}}">{{viewModel.badge}}</text>
    </view>

    <empty-state wx:if="{{viewModel.calendarCells.length === 0}}" title="{{viewModel.emptyText}}" />

    <view wx:else>
      <view class="chart-wrap">
        <canvas
          wx:if="{{hasChartData}}"
          class="trend-chart"
          canvas-id="trendLineChart"
          style="width: {{chartWidth}}px; height: {{chartHeight}}px;"
        ></canvas>
      </view>

      <view class="calendar-grid">
      <block wx:for="{{viewModel.calendarCells}}" wx:key="date">
        <view class="calendar-cell {{item.statusClass}} {{item.isSelected ? 'selected' : ''}}" data-date="{{item.date}}" bindtap="onCalendarCellTap">
          <text class="calendar-day">{{item.dayText}}</text>
          <text class="calendar-value">{{item.valueText}}</text>
        </view>
      </block>
      </view>
    </view>

    <view class="notice">趋势仅用于家庭记录和观察参考，不能替代医生判断。</view>
  </view>

  <view wx:if="{{detailModal.visible}}" class="modal-mask" catchtouchmove="noop" bindtap="onCloseDetailModal">
    <view class="detail-dialog" catchtap="noop">
      <view class="detail-head">
        <view>
          <text class="panel-title">{{detailModal.title}}</text>
          <text class="label">{{detailModal.subtitle}}</text>
        </view>
        <text class="badge">{{detailModal.countText}}</text>
      </view>

      <view wx:if="{{detailModal.records.length === 0}}" class="detail-record">
        <view>
          <text class="detail-title">{{detailModal.emptyTitle}}</text>
          <text class="detail-line">这一天还没有保存对应记录</text>
        </view>
      </view>

      <scroll-view wx:else class="detail-list" scroll-y>
        <block wx:for="{{detailModal.records}}" wx:key="id">
          <view class="detail-record">
            <view class="detail-copy">
              <text class="detail-title">{{item.title}}</text>
              <block wx:for="{{item.metaLines}}" wx:for-item="line" wx:key="*this">
                <text class="detail-line">{{line}}</text>
              </block>
            </view>
            <text wx:if="{{item.badgeText}}" class="badge {{item.badgeStatusClass === 'danger' ? 'danger' : item.badgeStatusClass === 'warn' ? 'warn' : ''}}">{{item.badgeText}}</text>
          </view>
        </block>
      </scroll-view>

      <button class="detail-close" bindtap="onCloseDetailModal">知道了</button>
    </view>
  </view>
</view>
